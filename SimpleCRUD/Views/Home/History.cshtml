@model IEnumerable<SimpleCRUD.Models.Inquiry>

@{
    ViewData["Title"] = "Submission Logs";
}

<section class="py-5 px-5 text-white" style="background-color: #0b061f; min-height: 80vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 style="font-size: 1.8rem; font-weight: 600; border-left: 4px solid #8b5cf6; padding-left: 12px; margin: 0;">
                Past Inquiries Database Log
            </h2>
            <p class="text-muted small m-0 mt-1">Reviewing active tracking forms stored in localdb context.</p>
        </div>
        <a href="/Home/Index#contact" class="btn btn-sm px-3" style="background-color: rgba(139, 92, 246, 0.15); color: #c0a5ff; border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 8px; font-weight: 500; line-height: 2;">
            + New Message
        </a>
    </div>

    <div class="mb-4 p-3 rounded-3" style="background-color: rgba(20, 10, 50, 0.3); border: 1px solid rgba(139, 92, 246, 0.15);">
        <form action="/Home/History" method="get" class="d-flex align-items-center gap-2">
            <div style="flex-grow: 1;">
                <input type="text" name="searchString" value="@ViewBag.CurrentFilter" placeholder="Search inquiries by sender name..." class="input-bg w-100" style="padding: 0.45rem 0.75rem; border-radius: 8px;" />
            </div>
            <button type="submit" class="btn px-4" style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.5), rgba(109, 40, 217, 0.3)); color: #fff; border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 8px; height: 38px;">
                Search
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentFilter))
            {
                <a href="/Home/History" class="btn btn-sm text-decoration-none d-flex align-items-center justify-content-center" style="color: #aaa; background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; height: 38px; padding: 0 15px;">
                    Clear
                </a>
            }
        </form>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="p-5 text-center rounded-3 shadow-sm" style="background-color: rgba(20, 10, 50, 0.2); border: 1px dashed rgba(139, 92, 246, 0.25);">
            <p class="m-0 text-muted" style="font-size: 1.05rem;">No matching inquiries found in the records system.</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow" style="border-radius: 12px; border: 1px solid rgba(139, 92, 246, 0.25); overflow: hidden;">
            <table class="table m-0 text-white" style="background-color: rgba(15, 8, 38, 0.95); border-color: rgba(255,255,255,0.05);">
                <include>
                    <thead style="background-color: rgba(139, 92, 246, 0.15); border-bottom: 2px solid rgba(139, 92, 246, 0.35);">
                        <tr>
                            <th class="py-3 px-4" style="color: #a78bfa; width: 70px;">ID</th>
                            <th class="py-3 px-4">Sender Details</th>
                            <th class="py-3 px-4">Subject Info</th>
                            <th class="py-3 px-4">Message Content</th>
                            <th class="py-3 px-4 text-center" style="width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr style="vertical-align: middle; border-bottom: 1px solid rgba(255,255,255,0.03);">
                                <td class="py-3 px-4" style="font-weight: bold; color: #a78bfa;">@item.Id</td>
                                <td class="py-3 px-4">
                                    <div style="font-weight: 500; color: #fff;">@item.Name</div>
                                    <div style="font-size: 0.85rem; color: #9CA3AF;">@item.Email</div>
                                </td>
                                <td class="py-3 px-4">
                                    <div style="font-weight: 500; color: #ffffff;">@item.Title</div>
                                    <span class="badge mt-1" style="background-color: rgba(139, 92, 246, 0.15); border: 1px solid rgba(139, 92, 246, 0.3); color: #c0a5ff; font-size: 0.75rem;">@item.Category</span>
                                </td>
                                <td class="py-3 px-4" style="color: #D1D5DB; font-size: 0.9rem; max-width: 350px; word-break: break-word; white-space: normal;">
                                    @item.Message
                                </td>
                                <td class="py-3 px-4 text-center">
                                    <form action="/Home/Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this log permanently?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm px-3" style="background-color: rgba(220, 53, 69, 0.15); color: #ff8793; border: 1px solid rgba(220, 53, 69, 0.4); border-radius: 6px; font-size: 0.8rem; transition: 0.2s;">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
            </table>
        </div>
    }
</section>