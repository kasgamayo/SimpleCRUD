@model SimpleCRUD.Models.Inquiry

@{
    ViewData["Title"] = "Message Sent";
}

<section class="py-5 px-5 text-white d-flex align-items-center justify-content-center" style="background-color: #0b061f; min-height: 80vh;">
    <div class="p-5 rounded-3 shadow" style="max-width: 650px; width: 100%; background-color: rgba(20, 10, 50, 0.4); border: 1px solid rgba(139, 92, 246, 0.3);">
        
        <div class="text-center mb-4">
            <div class="d-inline-flex justify-content-center align-items-center mb-2" style="width: 60px; height: 60px; background: rgba(139, 92, 246, 0.2); border-radius: 50%;">
                <span style="color: #a78bfa; font-size: 1.8rem; font-weight: bold;">✓</span>
            </div>
            <h2 style="font-size: 1.75rem; font-weight: 600;">Message Sent Successfully!</h2>
            <p class="text-muted small">Here is the detailed summary of your inquiry context:</p>
        </div>

        <div class="p-4 mb-4 rounded-3" style="background-color: rgba(15, 8, 38, 0.8); border: 1px solid rgba(255,255,255,0.05);">
            <div class="mb-3">
                <span class="text-muted small d-block">From:</span>
                <strong style="color: #fff; font-size: 1.05rem;">@Model.Name</strong> <span style="color: #9CA3AF; font-size: 0.9rem;">( @Model.Email )</span>
            </div>
            <div class="mb-3">
                <span class="text-muted small d-block">Subject Title & Category:</span>
                <span style="font-weight: 500;">@Model.Title</span>
                <span class="badge ms-2" style="background-color: rgba(139, 92, 246, 0.2); border: 1px solid rgba(139, 92, 246, 0.4); color: #c0a5ff;">@Model.Category</span>
            </div>
            <hr style="border-color: rgba(255,255,255,0.1);" />
            <div>
                <span class="text-muted small d-block mb-1">Your Message:</span>
                <p style="color: #D1D5DB; font-size: 0.95rem; white-space: pre-wrap; line-height: 1.6; margin: 0; word-break: break-word;">
                    @Model.Message
                </p>
            </div>
        </div>

        <div class="d-flex gap-2">
            <a href="/Home/Edit/@Model.Id" class="btn w-50 py-2 text-center text-decoration-none" style="background-color: rgba(139, 92, 246, 0.2); color: #c0a5ff; border: 1px solid rgba(139, 92, 246, 0.4); border-radius: 8px; font-weight: 500; transition: 0.2s;">
                Update Message
            </a>

            <form action="/Home/Delete" method="post" class="w-50" onsubmit="return confirm('Are you sure you want to delete this message permanently?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn w-100 py-2" style="background-color: rgba(220, 53, 69, 0.15); color: #ff8793; border: 1px solid rgba(220, 53, 69, 0.4); border-radius: 8px; font-weight: 500;">
                    Delete Message
                </button>
            </form>
        </div>

        <div class="text-center mt-4">
            <a href="/Home/Index" class="text-decoration-none small text-muted" style="transition: 0.2s;">
                ← Back to Homepage Form
            </a>
        </div>
    </div>
</section>