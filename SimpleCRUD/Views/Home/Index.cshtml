@model SimpleCRUD.Models.Inquiry

@{
    ViewData["Title"] = "Portfolio Home";
}

<section id="home" class="py-5 px-5 d-flex align-items-center justify-content-center text-center" style="background-color: #0b061f; color: #fff; min-height: 45vh;">
    <div style="max-width: 800px;">
        <h1 class="display-4 font-weight-bold" style="background: linear-gradient(135deg, #fff 30%, #a78bfa 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            Welcome!
        </h1>
        <p class="lead mt-3" style="font-size: 1.75rem; color: #D1D5DB;">
            Want to contact <span style="color: #8b5cf6; font-weight: 600;">Kelia Gamayo</span>?
        </p>
        <div class="mt-4">
            <a href="#contact" class="btn px-4 py-2" style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.6), rgba(109, 40, 217, 0.4)); color: #fff; border: 1px solid rgba(139, 92, 246, 0.4); border-radius: 20px; text-decoration: none;">
                Get in Touch Directly
            </a>
        </div>
    </div>
</section>

<section id="about" class="py-5 px-5 d-flex align-items-center justify-content-center" style="background-color: #0f0826; color: #fff; border-top: 1px solid rgba(139, 92, 246, 0.15); border-bottom: 1px solid rgba(139, 92, 246, 0.15); min-height: 35vh;">
    <div class="p-5 text-center rounded-3" style="max-width: 900px; background-color: rgba(20, 10, 50, 0.3); border: 1px solid rgba(139, 92, 246, 0.2);">
        <h2 class="mb-3" style="font-size: 2rem; font-weight: 600;">About This Site</h2>
        <p class="m-0 mx-auto" style="color: #D1D5DB; font-size: 1.1rem; line-height: 1.8;">
            This website is primarily made to contact Kelia Gamayo. It serves as a secure, structured space where clients, peers, or institutions can submit their formal inquiries, project proposals, or collaborative messages directly into the integrated SQL database pipeline.
        </p>
    </div>
</section>

<section id="contact" class="py-4 px-5 d-flex align-items-stretch gap-3" style="background-color: #0b061f; color: #fff; min-height: 60vh;">
    <div class="bg-animation bg-header p-4 w-100" style="--bg-cover: url('../assets/bg-header5.png'); background-color: rgba(20, 10, 50, 0.4); border-radius: 10px;">
        <div class="position-relative">
            <div class="d-flex align-items-start gap-3">
                <span class="fa--send"></span>
                <p class="text-capitalize" style="font-size: 1.5rem; color: #ffffff; font-weight: 600;">get in touch</p>
            </div>
            <p class="mt-2" style="color: #D1D5DB;">
                Let's collaborate and build something amazing together!
            </p>
        </div>
    </div>

    <div class="bg-animation p-4 w-100" style="background-color: rgba(20, 10, 50, 0.2); border-radius: 10px;">
        <div class="position-relative d-flex flex-column gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-3 d-flex justify-content-center align-items-center social-icon" style="width:35px; height:35px; background: linear-gradient(135deg, rgba(139, 92, 246, 0.5), rgba(109, 40, 217, 0.3));">
                    <span class="logos--google-gmail"></span>
                </div>
                <div class="lh-1">
                    <h3 class="m-0" style="font-size: 1.2rem;">Gmail</h3>
                    <a href="mailto:kagamayow@gmail.com" style="color: #D1D5DB; text-decoration: none;">kagamayow@gmail.com</a>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-3 d-flex justify-content-center align-items-center social-icon" style="width:35px; height:35px; background: linear-gradient(135deg, rgba(139, 92, 246, 0.5), rgba(109, 40, 217, 0.3));">
                    <span class="logos--google-gmail"></span>
                </div>
                <div class="lh-1">
                    <h3 class="m-0" style="font-size: 1.2rem;">PUP Student Email</h3>
                    <a href="mailto:keliaaudreysgamayo@iskolarmgbayan.pup.edu.ph" style="color: #D1D5DB; font-size: 0.85rem; text-decoration: none;">keliaaudreysgamayo@iskolarmgbayan.pup.edu.ph</a>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-3 d-flex justify-content-center align-items-center social-icon" style="width:35px; height:35px; background: linear-gradient(135deg, rgba(139, 92, 246, 0.5), rgba(109, 40, 217, 0.3));">
                    <span class="mdi--phone"></span>
                </div>
                <div class="lh-1">
                    <h3 class="m-0" style="font-size: 1.2rem;">Contact No.</h3>
                    <a href="tel:09393534330" style="color: #D1D5DB; text-decoration: none;">09393534330</a>
                </div>
            </div>
        </div>
    </div>

    <div class="w-100 d-flex">
        <form action="/Home/SubmitInquiry" method="post" class="d-flex flex-column gap-2 w-100">
            @Html.AntiForgeryToken()

            <div class="d-flex align-items-center gap-2 w-100">
                <div class="w-50">
                    <input type="text" name="Name" placeholder="Your Name" class="input-bg w-100" required />
                </div>
                <div class="w-50">
                    <input type="email" name="Email" placeholder="Your Email" class="input-bg w-100" required />
                </div>
            </div>

            <div class="d-flex align-items-center gap-2 w-100">
                <input type="text" name="Title" placeholder="Subject Title" class="input-bg w-50" required />

                <select name="Category" class="input-bg w-50" style="color: #fff; background-color: rgba(254,254,254,0.1); border: 1px solid rgba(139,92,246,0.3); padding: 0.375rem 0.75rem; border-radius: 10px; height: 100%;" required>
                    <option value="" style="background-color: #0b061f; color: #aaa;">-- Category --</option>
                    <option value="Work" style="background-color: #0b061f; color: #fff;">Work</option>
                    <option value="School" style="background-color: #0b061f; color: #fff;">School</option>
                    <option value="General" style="background-color: #0b061f; color: #fff;">General</option>
                    <option value="Others" style="background-color: #0b061f; color: #fff;">Others</option>
                </select>
            </div>

            <div class="d-flex flex-column flex-grow-1 w-100">
                <textarea name="Message" placeholder="Your Message" class="input-bg w-100 flex-grow-1" rows="4" required></textarea>
            </div>

            <button type="submit" class="btn w-100" style="background: linear-gradient(135deg, rgba(139, 92, 246, 0.5), rgba(109, 40, 217, 0.3)); color: #fff; border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 10px; padding: 10px; font-weight: 500;">
                Send Message
            </button>
        </form>
    </div>
</section>